#!/usr/bin/env python3
"""
slurm-mcp — synthetic Slurm scheduler MCP server for the Olympus demo.

Speaks Model Context Protocol (2024-11-05) over stdio. Returns
plausible synthetic data for a small GPU cluster so the Olympus HPC
agent has a real-feeling tool surface to call.

Tools:
  Read-only:
    nodes_list           — fleet roster + states (idle/alloc/drain/down)
    partitions_list      — partition definitions + node membership
    jobs_list            — current queue (pending + running)
    jobs_get(job_id)     — one job's full record
    accounting_summary   — last 24h rollup (completed / failed / cancelled)
    fairshare_list       — top users by fairshare score
    diagnostics          — slurmctld health
  Destructive (gated by Olympus's ApprovalHook):
    jobs_cancel(job_id)
    jobs_hold(job_id)
    jobs_release(job_id)
    jobs_requeue(job_id)

State is process-local — every spawn starts with the same canonical
fleet + queue, so the demo is reproducible across pod restarts.
"""
from __future__ import annotations

import os
import sys
import threading
from typing import Any

# Allow importing the shared protocol helper regardless of how the
# script is invoked (entry point, ConfigMap mount, etc.)
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _protocol import error_result, serve_stdio, text_result  # noqa: E402


SERVER_INFO = {"name": "slurm-mcp-demo", "version": "0.1.0"}


# ---------------------------------------------------------------------
# Synthetic fleet + queue
# ---------------------------------------------------------------------

_state_lock = threading.Lock()

_NODES: list[dict[str, Any]] = [
    {"name": "gpu-n01", "state": "alloc",     "cpus": 64, "gpus": 8, "mem_gb": 1024, "partition": "gpu"},
    {"name": "gpu-n02", "state": "alloc",     "cpus": 64, "gpus": 8, "mem_gb": 1024, "partition": "gpu"},
    {"name": "gpu-n03", "state": "idle",      "cpus": 64, "gpus": 8, "mem_gb": 1024, "partition": "gpu"},
    {"name": "gpu-n04", "state": "drain",     "cpus": 64, "gpus": 8, "mem_gb": 1024, "partition": "gpu",
     "reason": "ECC errors on GPU3 (XID 48)"},
    {"name": "cpu-n01", "state": "idle",      "cpus": 96, "gpus": 0, "mem_gb": 384,  "partition": "debug"},
    {"name": "cpu-n02", "state": "idle",      "cpus": 96, "gpus": 0, "mem_gb": 384,  "partition": "debug"},
]

_PARTITIONS: list[dict[str, Any]] = [
    {"name": "gpu",   "nodes": "gpu-n[01-04]", "default": True,  "max_walltime_h": 48, "preempt": True},
    {"name": "debug", "nodes": "cpu-n[01-02]", "default": False, "max_walltime_h": 1,  "preempt": False},
]

_JOBS: list[dict[str, Any]] = [
    {"job_id": 19431, "state": "RUNNING",  "user": "alice",  "partition": "gpu",   "nodes": "gpu-n01",   "gpus": 8,  "walltime_used_h": 4.2,  "walltime_limit_h": 12, "command": "torchrun pretrain.py"},
    {"job_id": 19432, "state": "RUNNING",  "user": "bob",    "partition": "gpu",   "nodes": "gpu-n02",   "gpus": 8,  "walltime_used_h": 1.5,  "walltime_limit_h": 8,  "command": "deepspeed sft.py"},
    {"job_id": 19433, "state": "PENDING",  "user": "carol",  "partition": "gpu",   "nodes": "(Resources)", "gpus": 16, "walltime_used_h": 0,    "walltime_limit_h": 6, "command": "torchrun eval_suite.py"},
    {"job_id": 19434, "state": "PENDING",  "user": "alice",  "partition": "gpu",   "nodes": "(Priority)",  "gpus": 8,  "walltime_used_h": 0,    "walltime_limit_h": 12, "command": "torchrun sweep.py --lr 1e-4"},
    {"job_id": 19435, "state": "RUNNING",  "user": "dave",   "partition": "debug", "nodes": "cpu-n01",   "gpus": 0,  "walltime_used_h": 0.1,  "walltime_limit_h": 1, "command": "make benchmark"},
    {"job_id": 19436, "state": "PENDING",  "user": "eve",    "partition": "gpu",   "nodes": "(Resources)", "gpus": 4,  "walltime_used_h": 0,    "walltime_limit_h": 6, "command": "lm-eval-harness"},
]


# ---------------------------------------------------------------------
# Read-only handlers
# ---------------------------------------------------------------------


def _fmt_nodes_table(nodes: list[dict[str, Any]]) -> str:
    head = f"{'NODE':<10} {'STATE':<8} {'CPUS':>5} {'GPUS':>5} {'MEM_GB':>7} {'PARTITION':<10} {'REASON'}"
    rows = [head, "-" * len(head)]
    for n in nodes:
        rows.append(
            f"{n['name']:<10} {n['state']:<8} {n['cpus']:>5} {n['gpus']:>5} "
            f"{n['mem_gb']:>7} {n['partition']:<10} {n.get('reason', '')}"
        )
    return "\n".join(rows)


def tool_nodes_list(_args: dict[str, Any]) -> dict[str, Any]:
    with _state_lock:
        return text_result(_fmt_nodes_table(list(_NODES)))


def tool_partitions_list(_args: dict[str, Any]) -> dict[str, Any]:
    with _state_lock:
        ps = list(_PARTITIONS)
    head = f"{'PARTITION':<10} {'NODES':<14} {'DEFAULT':<8} {'WALL_H':>7} {'PREEMPT'}"
    rows = [head, "-" * len(head)]
    for p in ps:
        rows.append(
            f"{p['name']:<10} {p['nodes']:<14} {'yes' if p['default'] else 'no':<8} "
            f"{p['max_walltime_h']:>7} {'yes' if p['preempt'] else 'no'}"
        )
    return text_result("\n".join(rows))


def tool_jobs_list(_args: dict[str, Any]) -> dict[str, Any]:
    with _state_lock:
        js = list(_JOBS)
    head = f"{'JOB_ID':<7} {'STATE':<9} {'USER':<8} {'PART':<6} {'NODES':<14} {'GPUS':>5} {'USED_H':>7} {'LIMIT_H':>8} COMMAND"
    rows = [head, "-" * len(head)]
    for j in js:
        rows.append(
            f"{j['job_id']:<7} {j['state']:<9} {j['user']:<8} {j['partition']:<6} "
            f"{j['nodes']:<14} {j['gpus']:>5} {j['walltime_used_h']:>7.1f} "
            f"{j['walltime_limit_h']:>8} {j['command']}"
        )
    return text_result("\n".join(rows))


def tool_jobs_get(args: dict[str, Any]) -> dict[str, Any]:
    try:
        job_id = int(args.get("job_id"))
    except (TypeError, ValueError):
        return error_result("jobs_get: 'job_id' (int) required")
    with _state_lock:
        for j in _JOBS:
            if j["job_id"] == job_id:
                return text_result("\n".join(f"{k} = {v}" for k, v in j.items()))
    return error_result(f"job {job_id} not found")


def tool_accounting_summary(_args: dict[str, Any]) -> dict[str, Any]:
    # Static synthetic 24h rollup; varies cleanly enough for the demo.
    return text_result(
        "Slurm accounting — last 24h:\n"
        "  completed: 187 jobs (1480 GPU-hours)\n"
        "  failed:     12 jobs (mostly OOM on alice@gpu)\n"
        "  cancelled:   5 jobs (operator)\n"
        "  timeout:     3 jobs\n"
        "  fairshare top user (last 24h): alice (4.3 effective)\n"
    )


def tool_fairshare_list(_args: dict[str, Any]) -> dict[str, Any]:
    rows = [
        ("alice",  4.3, 0.31),
        ("bob",    2.1, 0.18),
        ("carol",  1.7, 0.14),
        ("dave",   0.9, 0.05),
        ("eve",    0.6, 0.04),
    ]
    head = f"{'USER':<8} {'FAIRSHARE':>10} {'EFFECTIVE_USAGE':>17}"
    out = [head, "-" * len(head)]
    for u, fs, eu in rows:
        out.append(f"{u:<8} {fs:>10.2f} {eu:>17.2f}")
    return text_result("\n".join(out))


def tool_diagnostics(_args: dict[str, Any]) -> dict[str, Any]:
    return text_result(
        "slurmctld diagnostics:\n"
        "  server thread count: 32\n"
        "  agent queue size:    4 (healthy < 100)\n"
        "  rpc calls (24h):     14_823\n"
        "  scheduler:           backfill (last cycle 247ms)\n"
        "  primary controller:  healthy\n"
        "  backup controller:   standby, healthy\n"
    )


# ---------------------------------------------------------------------
# Destructive handlers — the Olympus runtime routes these through the
# approval queue (the MCP card registers them with destructive=[...]).
# Mutates the synthetic queue so a follow-up jobs_list shows the change.
# ---------------------------------------------------------------------


def _find_job(job_id: int) -> dict[str, Any] | None:
    for j in _JOBS:
        if j["job_id"] == job_id:
            return j
    return None


def tool_jobs_cancel(args: dict[str, Any]) -> dict[str, Any]:
    try:
        job_id = int(args.get("job_id"))
    except (TypeError, ValueError):
        return error_result("jobs_cancel: 'job_id' (int) required")
    with _state_lock:
        j = _find_job(job_id)
        if j is None:
            return error_result(f"job {job_id} not found")
        if j["state"] in ("COMPLETED", "CANCELLED"):
            return text_result(f"job {job_id} already {j['state']}")
        j["state"] = "CANCELLED"
        return text_result(f"cancelled job {job_id} (was {j.get('user')}@{j.get('partition')})")


def tool_jobs_hold(args: dict[str, Any]) -> dict[str, Any]:
    try:
        job_id = int(args.get("job_id"))
    except (TypeError, ValueError):
        return error_result("jobs_hold: 'job_id' (int) required")
    with _state_lock:
        j = _find_job(job_id)
        if j is None:
            return error_result(f"job {job_id} not found")
        if j["state"] != "PENDING":
            return error_result(f"can only hold PENDING jobs (job {job_id} is {j['state']})")
        j["state"] = "HELD"
        return text_result(f"held job {job_id}")


def tool_jobs_release(args: dict[str, Any]) -> dict[str, Any]:
    try:
        job_id = int(args.get("job_id"))
    except (TypeError, ValueError):
        return error_result("jobs_release: 'job_id' (int) required")
    with _state_lock:
        j = _find_job(job_id)
        if j is None:
            return error_result(f"job {job_id} not found")
        if j["state"] != "HELD":
            return error_result(f"can only release HELD jobs (job {job_id} is {j['state']})")
        j["state"] = "PENDING"
        return text_result(f"released job {job_id}")


def tool_jobs_requeue(args: dict[str, Any]) -> dict[str, Any]:
    try:
        job_id = int(args.get("job_id"))
    except (TypeError, ValueError):
        return error_result("jobs_requeue: 'job_id' (int) required")
    with _state_lock:
        j = _find_job(job_id)
        if j is None:
            return error_result(f"job {job_id} not found")
        if j["state"] not in ("RUNNING", "FAILED", "TIMEOUT"):
            return error_result(f"can only requeue RUNNING/FAILED/TIMEOUT jobs (job {job_id} is {j['state']})")
        j["state"] = "PENDING"
        j["walltime_used_h"] = 0
        return text_result(f"requeued job {job_id}")


# ---------------------------------------------------------------------
# Tool descriptors + entry point
# ---------------------------------------------------------------------


def _arg_schema_job_id() -> dict[str, Any]:
    return {
        "type": "object",
        "properties": {"job_id": {"type": "integer", "description": "Slurm job id"}},
        "required": ["job_id"],
        "additionalProperties": False,
    }


def _no_args_schema() -> dict[str, Any]:
    return {"type": "object", "properties": {}, "additionalProperties": False}


TOOLS: list[dict[str, Any]] = [
    {"name": "nodes_list", "description": "Roster of cluster nodes + their states (idle/alloc/drain/down).", "inputSchema": _no_args_schema()},
    {"name": "partitions_list", "description": "Slurm partitions and which nodes belong to each.", "inputSchema": _no_args_schema()},
    {"name": "jobs_list", "description": "Current job queue (pending + running).", "inputSchema": _no_args_schema()},
    {"name": "jobs_get", "description": "Full record for a single job.", "inputSchema": _arg_schema_job_id()},
    {"name": "accounting_summary", "description": "Last-24h rollup: completed / failed / cancelled / timeout counts + GPU-hour total.", "inputSchema": _no_args_schema()},
    {"name": "fairshare_list", "description": "Top users by Slurm fairshare score + effective usage.", "inputSchema": _no_args_schema()},
    {"name": "diagnostics", "description": "slurmctld health snapshot (thread / queue / RPC counters, scheduler state).", "inputSchema": _no_args_schema()},
    {"name": "jobs_cancel", "description": "Cancel a job. DESTRUCTIVE — Olympus routes through approval.", "inputSchema": _arg_schema_job_id()},
    {"name": "jobs_hold", "description": "Hold a PENDING job. DESTRUCTIVE.", "inputSchema": _arg_schema_job_id()},
    {"name": "jobs_release", "description": "Release a HELD job back to PENDING. DESTRUCTIVE.", "inputSchema": _arg_schema_job_id()},
    {"name": "jobs_requeue", "description": "Requeue a RUNNING / FAILED / TIMEOUT job. DESTRUCTIVE.", "inputSchema": _arg_schema_job_id()},
]


HANDLERS = {
    "nodes_list": tool_nodes_list,
    "partitions_list": tool_partitions_list,
    "jobs_list": tool_jobs_list,
    "jobs_get": tool_jobs_get,
    "accounting_summary": tool_accounting_summary,
    "fairshare_list": tool_fairshare_list,
    "diagnostics": tool_diagnostics,
    "jobs_cancel": tool_jobs_cancel,
    "jobs_hold": tool_jobs_hold,
    "jobs_release": tool_jobs_release,
    "jobs_requeue": tool_jobs_requeue,
}


def main() -> int:
    return serve_stdio(server_info=SERVER_INFO, tools=TOOLS, handlers=HANDLERS)


if __name__ == "__main__":
    sys.exit(main())
