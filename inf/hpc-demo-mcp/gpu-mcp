#!/usr/bin/env python3
"""
gpu-mcp — synthetic GPU health MCP server for the Olympus demo.

Speaks Model Context Protocol (2024-11-05) over stdio. Returns
plausible synthetic per-node nvidia-smi / ECC / XID / NVLink data so
the Olympus HPC agent has a real-feeling diagnostic surface for
``drain_advisor`` decisions.

All tools are read-only — Olympus's HPC agent only does drain
recommendations through this server; actual drain commands go through
slurm-mcp's jobs_hold + ``scontrol`` reach.
"""
from __future__ import annotations

import os
import sys
from typing import Any

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _protocol import error_result, serve_stdio, text_result  # noqa: E402


SERVER_INFO = {"name": "gpu-mcp-demo", "version": "0.1.0"}


