# ---------------------------------------------------------------------
# Handlers
# ---------------------------------------------------------------------


def tool_fleet_summary(_args: dict[str, Any]) -> dict[str, Any]:
    total = healthy = degraded = down = 0
    for node, info in _GPU_FLEET.items():
        for g in info["gpus"]:
            total += 1
            if g["ecc_dbe"] > 0 or g["row_remap_pending"] > 0:
                degraded += 1
            else:
                healthy += 1
        if info["nvlink_health"] != "OK":
            down += 1
    return text_result(
        f"GPU fleet summary ({len(_GPU_FLEET)} nodes):\n"
        f"  GPUs total:    {total}\n"
        f"  GPUs healthy:  {healthy}\n"
        f"  GPUs degraded: {degraded}\n"
        f"  nodes w/ degraded NVLink: {down}\n"
        f"  drain candidates (see drain_advisor): "
        + ", ".join(_drain_candidates()) or "(none)"
    )


def tool_node_status(args: dict[str, Any]) -> dict[str, Any]:
    node = (args.get("node") or "").strip()
    if not node:
        return error_result("node_status: 'node' (string) required")
    info = _GPU_FLEET.get(node)
    if info is None:
        return error_result(f"unknown node {node!r} (known: {sorted(_GPU_FLEET)})")
    lines = [
        f"Node: {node}",
        f"  model:  {info['model']}",
        f"  driver: {info['driver']} (CUDA {info['cuda']})",
        f"  NVLink: {info['nvlink_health']}",
        f"  DCGM:   {info['dcgm']['power_w']} W, throttle={','.join(info['dcgm']['throttle_reasons'])}",
        "  GPUs:",
        f"    {'IDX':>3} {'UTIL%':>6} {'TEMP_C':>7} {'MEM_USED/TOTAL':<18} {'ECC_SBE':>8} {'ECC_DBE':>8} {'REMAP_PEND':>11}",
    ]
    for g in info["gpus"]:
        lines.append(
            f"    {g['idx']:>3} {g['util_pct']:>6} {g['temp_c']:>7} "
            f"{g['mem_used_gb']:>5.1f}/{g['mem_total_gb']:<5.0f}GB   "
            f"{g['ecc_sbe']:>8} {g['ecc_dbe']:>8} {g['row_remap_pending']:>11}"
        )
    return text_result("\n".join(lines))


def tool_nvlink_topology(args: dict[str, Any]) -> dict[str, Any]:
    node = (args.get("node") or "").strip()
    if not node or node not in _GPU_FLEET:
        return error_result(f"unknown node {node!r}")
    info = _GPU_FLEET[node]
    # Fixed 8x8 H100 NVLink fully-connected matrix; degraded node loses
    # one link to mimic "GPU3 cable degraded".
    rows = ["NVLink topology:", "    " + " ".join(f"GPU{i}" for i in range(8))]
    for i in range(8):
        cells = []
        for j in range(8):
            if i == j:
                cells.append("  X ")
            elif info["nvlink_health"] != "OK" and (i == 3 or j == 3):
                cells.append("  - ")  # degraded link
            else:
                cells.append("NV6 ")  # 6-link H100 fabric
        rows.append(f"GPU{i} " + " ".join(c.strip().rjust(4) for c in cells))
    return text_result("\n".join(rows))


def tool_xid_recent(args: dict[str, Any]) -> dict[str, Any]:
    node = (args.get("node") or "").strip()
    if not node:
        return error_result("xid_recent: 'node' (string) required")
    info = _GPU_FLEET.get(node)
    if info is None:
        return error_result(f"unknown node {node!r}")
    events: list[tuple[str, int, int, str]] = []
    for g in info["gpus"]:
        for e in g["xid_recent"]:
            events.append((e["ts"], g["idx"], e["xid"], e["msg"]))
    if not events:
        return text_result(f"no recent XID events on {node}")
    out = [f"Recent XID events on {node} (last 1h):"]
    for ts, idx, xid, msg in events:
        out.append(f"  {ts}  GPU{idx}  XID {xid}: {msg}")
    return text_result("\n".join(out))


def tool_dcgm_metrics(args: dict[str, Any]) -> dict[str, Any]:
    node = (args.get("node") or "").strip()
    if not node or node not in _GPU_FLEET:
        return error_result(f"unknown node {node!r}")
    info = _GPU_FLEET[node]
    return text_result(
        f"DCGM metrics ({node}):\n"
        f"  total_power_w: {info['dcgm']['power_w']}\n"
        f"  throttle_reasons: {', '.join(info['dcgm']['throttle_reasons'])}\n"
        f"  per-GPU util (avg): {sum(g['util_pct'] for g in info['gpus']) / 8:.1f}%\n"
        f"  per-GPU temp (avg): {sum(g['temp_c']  for g in info['gpus']) / 8:.1f} °C\n"
    )


def _drain_candidates() -> list[str]:
    out = []
    for node, info in _GPU_FLEET.items():
        for g in info["gpus"]:
            if g["ecc_dbe"] > 0 or g["row_remap_pending"] > 0:
                out.append(node)
                break
        else:
            if info["nvlink_health"] != "OK":
                out.append(node)
    return out


def tool_drain_advisor(_args: dict[str, Any]) -> dict[str, Any]:
    cands = _drain_candidates()
    if not cands:
        return text_result("No GPU health issues — no drain recommended.")
    lines = ["Drain recommendation (operator should review before acting):"]
    for node in cands:
        info = _GPU_FLEET[node]
        reasons = []
        for g in info["gpus"]:
            if g["ecc_dbe"] > 0:
                reasons.append(f"GPU{g['idx']}: {g['ecc_dbe']} DBE")
            if g["row_remap_pending"] > 0:
                reasons.append(f"GPU{g['idx']}: {g['row_remap_pending']} row remap(s) pending")
        if info["nvlink_health"] != "OK":
            reasons.append(f"NVLink: {info['nvlink_health']}")
        lines.append(f"  {node}: " + "; ".join(reasons))
        lines.append("    suggested action: scontrol update nodename=" + node + " state=drain reason=\"GPU health\"")
    return text_result("\n".join(lines))


# ---------------------------------------------------------------------
# Tool descriptors + entry point
# ---------------------------------------------------------------------


def _arg_schema_node() -> dict[str, Any]:
    return {
        "type": "object",
        "properties": {"node": {"type": "string", "description": "Node name, e.g. gpu-n01"}},
        "required": ["node"],
        "additionalProperties": False,
    }


def _no_args_schema() -> dict[str, Any]:
    return {"type": "object", "properties": {}, "additionalProperties": False}


TOOLS: list[dict[str, Any]] = [
    {"name": "fleet_summary", "description": "Fleet-wide rollup: total / healthy / degraded GPU counts + drain candidates.", "inputSchema": _no_args_schema()},
    {"name": "node_status", "description": "Per-GPU details for one node — util, temp, mem, ECC counters.", "inputSchema": _arg_schema_node()},
    {"name": "nvlink_topology", "description": "NVLink fabric matrix for one node (degraded links marked).", "inputSchema": _arg_schema_node()},
    {"name": "xid_recent", "description": "Recent XID events on one node (last hour). Empty if healthy.", "inputSchema": _arg_schema_node()},
    {"name": "dcgm_metrics", "description": "Key DCGM metrics (power, throttle, average util/temp) for one node.", "inputSchema": _arg_schema_node()},
    {"name": "drain_advisor", "description": "Operator-facing recommendation: which nodes should be drained + why.", "inputSchema": _no_args_schema()},
]


HANDLERS = {
    "fleet_summary": tool_fleet_summary,
    "node_status": tool_node_status,
    "nvlink_topology": tool_nvlink_topology,
    "xid_recent": tool_xid_recent,
    "dcgm_metrics": tool_dcgm_metrics,
    "drain_advisor": tool_drain_advisor,
}


def main() -> int:
    return serve_stdio(server_info=SERVER_INFO, tools=TOOLS, handlers=HANDLERS)


if __name__ == "__main__":
    sys.exit(main())
