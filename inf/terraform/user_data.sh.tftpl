#!/usr/bin/env bash
# Minimal first-boot shim: export the deploy knobs, clone the sandbox repo,
# and hand off to the role script. The placeholders below are Terraform
# template vars; shell variables are written as $NAME (no braces) so the
# template engine leaves them untouched.
set -e
export DEBIAN_FRONTEND=noninteractive

export SANDBOX_REPO_URL="${sandbox_repo_url}"
export SANDBOX_REPO_REF="${sandbox_repo_ref}"
export OLYMPUS_REPO_URL="${olympus_repo_url}"
export OLYMPUS_REPO_REF="${olympus_repo_ref}"
export OLYMPUS_ROUTER="${olympus_router}"
export OLYMPUS_NAMESPACE="olympus"
export OLYMPUS_RELEASE="olympus"
export IMAGE_TAG="llm"
export OPENAI_API_KEY="${openai_api_key}"
export ANTHROPIC_API_KEY="${anthropic_api_key}"
export MASTER_IP="${master_ip}"
export JOIN_TOKEN="${join_token}"
export POD_CIDR="${pod_cidr}"
export K8S_VERSION="${k8s_version}"
export NODE_PORT="${node_port}"
export PUBLIC_IP="${public_ip}"
export DNS_HOSTNAME="${dns_hostname}"
export CERTBOT_EMAIL="${certbot_email}"
export CERTBOT_STAGING="${certbot_staging}"

# Retry apt — EC2 mirrors are occasionally mid-sync at instance birth.
aptq() { for i in $(seq 1 8); do apt-get -o Acquire::Retries=3 "$@" && return 0; echo "[apt] retry $i: $*"; sleep 15; done; return 1; }
aptq update
aptq install -y git
rm -rf /opt/sandbox
git clone --depth 1 --branch "$SANDBOX_REPO_REF" "$SANDBOX_REPO_URL" /opt/sandbox
bash /opt/sandbox/inf/bootstrap/${role}.sh
