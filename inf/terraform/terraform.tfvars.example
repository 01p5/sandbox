# Copy to terraform.tfvars (gitignored) and adjust. Every value has a
# default in variables.tf — you can run with an empty tfvars.
#
# NOTE: cluster/deploy knobs (k8s version, Olympus repo, router, certbot)
# live in inf/ansible/group_vars/all.yml, not here. Terraform only stands
# up the boxes + DNS and writes the Ansible inventory.

aws_region    = "us-west-2" # Oregon
customer_name = "sandbox"

control_plane_instance_type = "t3.medium"
worker_instance_type        = "t3.large"
root_volume_size            = 40

# Tighten SSH to your IP for anything non-throwaway.
# ssh_ingress_cidr = "203.0.113.4/32"

dns_hostname = "0lympu5.com"

# Cloudflare token via env only — NEVER commit:
#   export TF_VAR_cloudflare_api_token=...
cloudflare_zone_id = "63b9172374ab880f8fe2f2311f05dc6e"
