#!/usr/bin/env bash
# Optional convenience: source this to set Terraform vars + secrets without
# committing them.
#
#   cp env.sh.template env.sh   # env.sh is gitignored
#   # edit, then:
#   source env.sh
#
# Most values have defaults in inf/terraform/variables.tf; this file is
# mainly for the secrets, which must never be committed.

export AWS_REGION="us-west-2"             # Oregon
export TF_VAR_aws_region="us-west-2"
export TF_VAR_customer_name="sandbox"

# Tighten SSH to your own address for anything you leave running.
# export TF_VAR_ssh_ingress_cidr="203.0.113.4/32"

# ---- Deploy target (YOUR domain) — REQUIRED ----
# The hostname the dashboard is served at (DNS A-record + TLS cert CN). The
# committed defaults are example.com placeholders; set these to a domain you
# control in a Cloudflare zone. deploy.sh threads dns_hostname into both
# terraform and ansible, so you only set it here.
export TF_VAR_dns_hostname="olympus.example.com"
export DEPLOY_CERTBOT_EMAIL="admin@example.com"        # Let's Encrypt registration / expiry notices

# Cloudflare API token (Zone:DNS:Edit on the target zone). REQUIRED for the
# stack to manage DNS; leave blank to point DNS by hand instead. Also used by
# `deploy.sh netdb-up` for the lab.* NS delegation.
export TF_VAR_cloudflare_api_token=""
export TF_VAR_cloudflare_zone_id=""        # zone id of YOUR domain (zone Overview page)

# ---- NetDB / Technitium DNS server (inf/netdb · `deploy.sh netdb-up`) ----
# Optional self-service IPAM/DNS/DHCP. Stand up the persistent DNS server with
# `deploy.sh netdb-up`, then set netdb_mcp_host (+ netdb_delegated_zone,
# delegated_zone/ns_hostname/cloudflare_zone_* in inf/netdb/terraform) and
# redeploy. Required only if you run netdb-up:
export DNS_SERVER_ADMIN_PASSWORD=""   # Technitium admin password (compose needs it)
export NETDB_CLOUDFLARE_TOKEN=""      # optional: netdb's own Cloudflare provider

# LLM routing. deploy.sh defaults the router to "manual" (runs with NO provider
# key — deterministic keyword routing). Set OLYMPUS_ROUTER=llm and a key below to
# exercise the LLM-driven agents + the group-chat coordinator.
export OLYMPUS_ROUTER="manual"            # or "llm"
export OPENAI_API_KEY=""                  # or set ANTHROPIC_API_KEY
export ANTHROPIC_API_KEY=""

# --- Auth + email-OTP + hardening (Phases A-D). ---
#
# These are *not* Terraform vars — they're passed to ansible-playbook via
# `-e` at deploy time (see inf/README.md). They land in the dashboard pod
# as OLYMPUS_AUTH_* / OLYMPUS_DEMO_MODE / OLYMPUS_DAILY_COST_CAP_USD envs,
# either as plain values (allowlist, redirect, demo flags) or as keys in
# the sealed `olympus-secrets` Kubernetes Secret (session secret, Google
# client secret, SMTP password).
#
# deploy.sh reads these env vars and passes them through; you don't run
# ansible-playbook by hand.

# Who may log in. Comma-separated email domains (e.g. "example.com,acme.org"),
# or "*" to allow ANY authenticated Google/OTP email. Empty = no one passes the
# allowlist (set this before opening the dashboard to others).
export DEPLOY_AUTH_ALLOWED_DOMAINS=""

# Super-admins for the /admin page (per-user accounting + caps). Same syntax as
# allowed-domains plus exact emails: "alice@x.com", "*@x.com", or "*".
export DEPLOY_AUTH_ADMIN_EMAILS=""

export OLYMPUS_SESSION_SECRET=""        # 32+ random bytes: `head -c 32 /dev/urandom | base64`
export OLYMPUS_GOOGLE_CLIENT_ID=""      # from Google Cloud Console OAuth client (Web)
export OLYMPUS_GOOGLE_CLIENT_SECRET=""
export OLYMPUS_SMTP_HOST=""             # empty disables email-OTP (AWS SES recommended in us-west-2)
export OLYMPUS_SMTP_USERNAME=""
export OLYMPUS_SMTP_PASSWORD=""
export OLYMPUS_SMTP_FROM=""             # e.g. noreply@<your-domain>
# demo_mode + daily_cost_cap_usd have safe defaults in group_vars/all.yml
# (false / $5) — override at deploy time with `-e demo_mode=true` etc.
