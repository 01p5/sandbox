#!/usr/bin/env bash
# Optional convenience: source this to set Terraform vars + secrets without
# committing them.
#
#   cp env.sh.template env.sh   # env.sh is gitignored
#   # edit, then:
#   source env.sh
#
# Most values have defaults in inf/terraform/variables.tf; this file is
# mainly for the secrets, which must never be committed.

export AWS_REGION="us-west-2"             # Oregon
export TF_VAR_aws_region="us-west-2"
export TF_VAR_customer_name="sandbox"

# Tighten SSH to your own address for anything you leave running.
# export TF_VAR_ssh_ingress_cidr="203.0.113.4/32"

# Cloudflare API token (Zone:DNS:Edit on the target zone). REQUIRED for the
# stack to manage DNS; leave blank to point DNS by hand instead.
export TF_VAR_cloudflare_api_token=""

# LLM routing. Leave router "manual" to run with no key; set "llm" and a
# key below to exercise the LLM-driven agents.
# export TF_VAR_olympus_router="llm"
export TF_VAR_openai_api_key=""
export TF_VAR_anthropic_api_key=""
