# Copy to terraform.tfvars and set these to YOUR values. Secrets (the
# Cloudflare token) come from the environment via TF_VAR_cloudflare_api_token
# (see inf/env.sh) — do NOT put the token here.

aws_region    = "us-west-2"
customer_name = "sandbox"

# The zone Technitium becomes authoritative for, its NS hostname, and the
# PARENT Cloudflare zone they live under. The parent zone must already exist
# in your Cloudflare account.
delegated_zone       = "lab.example.com"
ns_hostname          = "ns1.lab.example.com"
cloudflare_zone_name = "example.com"
cloudflare_zone_id   = "<your-cloudflare-zone-id>" # zone Overview page

# Lock these down for a real deployment:
#   admin_cidr       = "<your-ip>/32"       # SSH + Technitium console (5380)
#   mcp_ingress_cidr = "<cluster-eip>/32"   # who can drive netdb /mcp (8080)
admin_cidr       = "0.0.0.0/0"
mcp_ingress_cidr = "0.0.0.0/0"
