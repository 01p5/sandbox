# Rendered by inf/netdb/ansible/netdb.yml — do not hand-edit on the host.
NETDB_ADDR=:8080
NETDB_DB=/data/netdb.sqlite
NETDB_RECONCILE_INTERVAL=60s

# --- Technitium (runs in this compose stack) ---
# netdb auto-bootstraps a permanent API token from the admin user+password
# on first use, so we set the password = the Technitium admin password.
DNS_SERVER_ADMIN_PASSWORD={{ dns_server_admin_password }}
DNS_SERVER_DOMAIN={{ ns_hostname }}
NETDB_TECHNITIUM_URL=http://dns-server:5380
NETDB_TECHNITIUM_USER=admin
NETDB_TECHNITIUM_PASSWORD={{ dns_server_admin_password }}
NETDB_TECHNITIUM_INSECURE=false

# --- Cloudflare (optional 2nd provider) --- blank = not used.
NETDB_CLOUDFLARE_TOKEN={{ netdb_cloudflare_token | default('') }}

# --- Kea (DHCP) ---
NETDB_KEA_URL=http://kea-ctrl-agent:8000/
NETDB_KEA_SYNC_INTERVAL=60s
NETDB_KEA_LEASE_POLL_INTERVAL=30s

# --- Auth OFF on purpose ---
# The SG locks port 8080 to the Olympus cluster (var.mcp_ingress_cidr), and
# Olympus's MCP HTTP client doesn't send basic-auth — so leave these empty
# and do NOT widen 8080. /healthz + /static are open regardless.
NETDB_USER=
NETDB_PASSWORD=
